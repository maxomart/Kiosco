# ============================================================
# KIOSCO APP - Variables de entorno
# Copiá este archivo como .env y completá los valores
# ============================================================

# ------------------------------------------------------------
# Base de datos PostgreSQL (OBLIGATORIA)
# En Railway, esta variable se genera automáticamente al
# conectar un servicio de Postgres al proyecto.
# ------------------------------------------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/kiosco_db"

# ------------------------------------------------------------
# NextAuth (OBLIGATORIAS)
# NEXTAUTH_SECRET: cadena aleatoria de 32+ caracteres.
#   Generar con: openssl rand -base64 32
# NEXTAUTH_URL: URL completa con https:// de tu deploy.
#   Ej Railway: https://kiosco-production-xxxx.up.railway.app
# ------------------------------------------------------------
NEXTAUTH_SECRET="cambiar-esto-por-una-clave-segura-de-32-caracteres"
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------------------------
# Super Admin (OPCIONALES)
# Credenciales del usuario SUPER_ADMIN que se crea al deploy.
# Si no se setean, se usan los valores por defecto:
#   superadmin@kiosco.com / SuperAdmin2026!
# ------------------------------------------------------------
# SUPERADMIN_EMAIL="superadmin@kiosco.com"
# SUPERADMIN_PASSWORD="SuperAdmin2026!"
# SUPERADMIN_NAME="Super Administrador"

# ------------------------------------------------------------
# Anthropic AI (OPCIONAL — para funciones de IA)
# Obtener en https://console.anthropic.com
# ------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-api03-..."

# ============================================================
# OPCIONALES
# ============================================================

# Notificaciones WhatsApp (Twilio)
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""

# Email (para alertas de stock bajo)
# EMAIL_SERVER_HOST="smtp.gmail.com"
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER="tu-email@gmail.com"
# EMAIL_SERVER_PASSWORD="tu-app-password"
# EMAIL_FROM="KioscoApp <tu-email@gmail.com>"

# AFIP (para facturación electrónica)
# AFIP_CUIT=""
# AFIP_CERT_PATH=""
# AFIP_KEY_PATH=""
# AFIP_ENVIRONMENT="testing" # o "production"
