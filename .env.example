# ============================================================
# KIOSCO APP - Variables de entorno
# Copiá este archivo como .env y completá los valores
# ============================================================

# Base de datos PostgreSQL
# Opción 1: Local (Docker)
DATABASE_URL="postgresql://postgres:password@localhost:5432/kiosco_db"
# Opción 2: Supabase (pegar la connection string desde el dashboard)
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"
# Opción 3: Railway
# DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/railway"

# NextAuth
NEXTAUTH_SECRET="cambiar-esto-por-una-clave-segura-de-32-caracteres"
NEXTAUTH_URL="http://localhost:3000"
# En producción:
# NEXTAUTH_URL="https://tu-dominio.com"

# Anthropic AI (para funciones de IA integradas)
# Obtener en https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-api03-..."

# ============================================================
# MULTI-KIOSCO
# Cuando vendés la app a varios clientes, cada uno tiene su
# propio deploy en Vercel con su propia DATABASE_URL.
# Podés personalizar el nombre por deployment:
# KIOSCO_NAME="Kiosco Don Julio"
# ============================================================

# ============================================================
# OPCIONALES
# ============================================================

# Notificaciones WhatsApp (Twilio)
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""

# Email (para alertas de stock bajo)
# EMAIL_SERVER_HOST="smtp.gmail.com"
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER="tu-email@gmail.com"
# EMAIL_SERVER_PASSWORD="tu-app-password"
# EMAIL_FROM="KioscoApp <tu-email@gmail.com>"

# AFIP (para facturación electrónica)
# AFIP_CUIT=""
# AFIP_CERT_PATH=""
# AFIP_KEY_PATH=""
# AFIP_ENVIRONMENT="testing" # o "production"
