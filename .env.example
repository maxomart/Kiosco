# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/retailar"
# Local dev SQLite alternativa: "file:./dev.db"

# ─── AUTH ────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="genera-uno-con: openssl rand -base64 32"
NEXTAUTH_URL="https://tu-app.up.railway.app"
# Local dev: NEXTAUTH_URL="http://localhost:3000"

# ─── SUPER ADMIN (se crea automático al deployar) ────────────────────────────
SUPERADMIN_EMAIL="admin@retailar.app"
SUPERADMIN_PASSWORD="SuperAdmin2026!"
SUPERADMIN_NAME="Super Admin"

# ─── STRIPE ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# IDs de los precios en Stripe Dashboard:
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_PROFESSIONAL="price_..."
STRIPE_PRICE_BUSINESS="price_..."

# ─── AI ASSISTANT (OpenAI / GPT-4o-mini) ─────────────────────────────────────
# Required for the in-app AI assistant. Get a key at https://platform.openai.com/api-keys
# Default model: gpt-4o-mini (fast + cheap). Edit lib/openai.ts to change.
OPENAI_API_KEY="sk-..."

# ─── WHATSAPP NOTIFICATIONS (Twilio) ─────────────────────────────────────────
# Required for sending WhatsApp alerts. Sign up at https://twilio.com,
# activate WhatsApp Sandbox (or get production approval), then:
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_WHATSAPP_FROM="+14155238886"   # The Twilio sandbox number (or your prod WA number)

# ─── CRON / SCHEDULED TASKS ──────────────────────────────────────────────────
# Long random string used to authenticate scheduled jobs (daily WhatsApp summary, etc.).
# Generate one with: openssl rand -hex 48
# Then in Railway: Project → Cron → POST {URL}/api/cron/daily-summary daily at 22:00
# with header `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET="cambia-esto-por-algo-largo-y-aleatorio"

# ─── OPTIONAL ────────────────────────────────────────────────────────────────
# CLOUDINARY_URL="cloudinary://..."  # Para imágenes de productos
# NEXT_PUBLIC_APP_URL="https://tu-app.up.railway.app"
