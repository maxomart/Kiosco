# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/orvex"
# Local dev SQLite alternativa: "file:./dev.db"

# ─── AUTH ────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="genera-uno-con: openssl rand -base64 32"
NEXTAUTH_URL="https://tu-app.up.railway.app"
# Local dev: NEXTAUTH_URL="http://localhost:3000"

# ─── SEO / Dominio público ───────────────────────────────────────────────────
# URL pública para sitemap, robots, canonical, OG.
NEXT_PUBLIC_SITE_URL="https://cobraorvex.com"

# ─── EMAIL (notificaciones por mail) ─────────────────────────────────────────
# Usamos Resend (https://resend.com) — gratis hasta 3.000 emails/mes
RESEND_API_KEY=""
# Dominio verificado en Resend (o usá onboarding@resend.dev para pruebas)
EMAIL_FROM="Orvex <noreply@cobraorvex.com>"
# Cuando alguien responde un email automático, llega a esta casilla (tu Gmail)
EMAIL_REPLY_TO="cobraorvex@gmail.com"

# ─── SUPER ADMIN (se crea automático al deployar) ────────────────────────────
SUPERADMIN_EMAIL="admin@cobraorvex.com"
# SUPERADMIN_PASSWORD: si la dejás vacía, se genera una aleatoria segura
# y se imprime UNA SOLA VEZ en los logs del primer deploy.
# Mínimo 10 caracteres si la definís.
SUPERADMIN_PASSWORD=""
SUPERADMIN_NAME="Super Admin"

# ─── STRIPE ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# IDs de los precios en Stripe Dashboard:
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_PROFESSIONAL="price_..."
STRIPE_PRICE_BUSINESS="price_..."

# ─── MERCADOPAGO SUSCRIPCIONES (billing en ARS) ──────────────────────────────
# Platform-level MercadoPago account (for billing tenant subscriptions in ARS).
# Get the access token at https://www.mercadopago.com.ar/developers — your own
# (the SaaS company's) account, NOT each tenant's.
#
# Webhook URL to register in MP Dashboard → Tus integraciones → Webhooks:
#   ${NEXTAUTH_URL}/api/billing/mp/webhook
# Suscribite a los eventos: "Pagos" y "Suscripciones (Preapproval)".
MP_PLATFORM_ACCESS_TOKEN="APP_USR-..."
MP_WEBHOOK_SECRET="<long random string for HMAC verification>"

# ─── AI ASSISTANT (OpenAI / GPT-4o-mini) ─────────────────────────────────────
# Required for the in-app AI assistant. Get a key at https://platform.openai.com/api-keys
# Default model: gpt-4o-mini (fast + cheap). Edit lib/openai.ts to change.
OPENAI_API_KEY="sk-..."

# ─── WHATSAPP NOTIFICATIONS (Meta Cloud API) ────────────────────────────────
# Usa la Meta WhatsApp Business Cloud API.
# Setup: https://developers.facebook.com → Crea app → Agregar "WhatsApp" → Configura tu número
# Get access token with whatsapp_business_messaging permission (long-lived, 60 days).
# Get Phone Number ID from WhatsApp Dashboard → API Setup.
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_WHATSAPP_FROM="whatsapp:+1415523XXXX"

# ─── MOBBEX (pago alternativo en ARS, depósitos en 2-3 días) ─────────────────
# Registrate en https://mobbex.com → Panel → Configuración → API
# Webhook URL a registrar en Mobbex: ${NEXTAUTH_URL}/api/billing/mobbex/webhook
MOBBEX_API_KEY="appkey_..."
MOBBEX_ACCESS_TOKEN="eyJ..."

# ─── CRON / SCHEDULED TASKS ──────────────────────────────────────────────────
# Long random string used to authenticate scheduled jobs (daily WhatsApp summary, etc.).
# Generate one with: openssl rand -hex 48
# Then in Railway: Project → Cron → POST {URL}/api/cron/daily-summary daily at 22:00
# with header `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET="cambia-esto-por-algo-largo-y-aleatorio"

# ─── GOOGLE SHEETS REALTIME SYNC ─────────────────────────────────────────────
# Sincronización en tiempo real de signups y pagos a Google Sheets vía Apps
# Script Web App. Setup:
#   1. Crear 2 Sheets en Drive: "Orvex - Usuarios" y "Orvex - Pagos"
#   2. En cada uno: Extensiones → Apps Script → pegar el código de doc/...
#   3. Implementar como Web App (cualquier persona, ejecutar como yo)
#   4. Pegar las URLs acá abajo
# El secret es un string aleatorio largo (mismo en Apps Script y en estas vars).
# Generalo con: openssl rand -hex 24
SHEETS_WEBHOOK_SECRET=""
SHEETS_WEBHOOK_USERS_URL=""
SHEETS_WEBHOOK_PAYMENTS_URL=""

# ─── OPTIONAL ────────────────────────────────────────────────────────────────
# CLOUDINARY_URL="cloudinary://..."  # Para imágenes de productos
# NEXT_PUBLIC_APP_URL="https://tu-app.up.railway.app"
