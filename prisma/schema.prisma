datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============= MULTI-TENANT CORE =============
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  products    Product[]
  sales       Sale[]
  clients     Client[]
  suppliers   Supplier[]
  expenses    Expense[]
  recharges   Recharge[]
  cashSessions CashSession[]
  categories  Category[]
  config      TenantConfig?
  subscription Subscription?

  @@index([active])
  @@index([createdAt])
}

// ============= AUTH & USERS =============
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String?
  role      String   @default("CASHIER")
  active    Boolean  @default(true)
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String?
  tenant   Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sales          Sale[]
  stockMovements StockMovement[]
  auditLogs      AuditLog[]
  cashSessions   CashSession[]

  @@index([email])
  @@index([tenantId])
  @@index([role])
}

// ============= PRODUCTS & INVENTORY =============
model Product {
  id           String   @id @default(cuid())
  name         String
  description  String?
  sku          String?
  barcode      String?
  costPrice    Decimal  @default(0) @db.Decimal(10, 2)
  salePrice    Decimal  @default(0) @db.Decimal(10, 2)
  stock        Int      @default(0)
  minStock     Int      @default(5)
  maxStock     Int?
  active       Boolean  @default(true)
  image        String?
  soldByWeight Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  saleItems      SaleItem[]
  stockMovements StockMovement[]

  @@unique([barcode, tenantId])
  @@unique([sku, tenantId])
  @@index([tenantId])
  @@index([active])
  @@index([categoryId])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([name, tenantId])
  @@index([tenantId])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  cuit      String?
  contact   String?
  phone     String?
  email     String?
  address   String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]
  recharges Recharge[]

  @@index([tenantId])
  @@index([active])
}

model StockMovement {
  id          String   @id @default(cuid())
  type        String   // SALE, PURCHASE, ADJUSTMENT, RETURN, LOSS
  quantity    Int
  stockBefore Int
  stockAfter  Int
  unitCost    Decimal? @db.Decimal(10, 2)
  totalCost   Decimal? @db.Decimal(10, 2)
  reason      String?
  reference   String?
  createdAt   DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

// ============= SALES =============
model Sale {
  id              String   @id @default(cuid())
  number          Int
  subtotal        Decimal  @db.Decimal(12, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(12, 2)
  discountPercent Decimal  @default(0) @db.Decimal(5, 2)
  taxAmount       Decimal  @default(0) @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)
  paymentMethod   String   @default("CASH")
  cashReceived    Decimal? @db.Decimal(12, 2)
  change          Decimal? @db.Decimal(12, 2)
  status          String   @default("COMPLETED")
  cancelReason    String?
  notes           String?
  invoiceType     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id])
  cashSessionId String?
  cashSession   CashSession? @relation(fields: [cashSessionId], references: [id])

  items                SaleItem[]
  loyaltyTransactions  LoyaltyTransaction[]

  @@unique([number, tenantId])
  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model SaleItem {
  id          String  @id @default(cuid())
  productName String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  costPrice   Decimal @db.Decimal(10, 2)
  discount    Decimal @default(0) @db.Decimal(5, 2)
  subtotal    Decimal @db.Decimal(12, 2)
  taxRate     String  @default("STANDARD")
  taxAmount   Decimal @default(0) @db.Decimal(12, 2)

  productId String
  product   Product @relation(fields: [productId], references: [id])
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([productId])
}

// ============= CLIENTS & LOYALTY =============
model Client {
  id            String   @id @default(cuid())
  name          String
  phone         String?
  email         String?
  dni           String?
  address       String?
  notes         String?
  active        Boolean  @default(true)
  loyaltyPoints Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sales               Sale[]
  loyaltyTransactions LoyaltyTransaction[]

  @@unique([dni, tenantId])
  @@index([tenantId])
  @@index([active])
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  points      Int
  description String
  createdAt   DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  saleId   String?
  sale     Sale?   @relation(fields: [saleId], references: [id])

  @@index([clientId])
}

// ============= CASH REGISTER =============
model CashSession {
  id             String    @id @default(cuid())
  status         String    @default("OPEN")
  openingBalance Decimal   @db.Decimal(12, 2)
  closingBalance Decimal?  @db.Decimal(12, 2)
  difference     Decimal?  @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime  @default(now())
  closedAt       DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  sales Sale[]

  @@index([tenantId])
  @@index([status])
}

// ============= EXPENSES & RECHARGES =============
model Expense {
  id        String   @id @default(cuid())
  category  String
  amount    Decimal  @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([createdAt])
}

model Recharge {
  id        String   @id @default(cuid())
  number    Int
  cost      Decimal  @db.Decimal(12, 2)
  profit    Decimal  @db.Decimal(12, 2)
  amount    Decimal  @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime @default(now())

  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  @@unique([number, tenantId])
  @@index([tenantId])
}

// ============= SUBSCRIPTIONS =============
model Subscription {
  id                   String    @id @default(cuid())
  plan                 String    @default("FREE")
  status               String    @default("ACTIVE")
  priceUSD             Decimal   @default(0) @db.Decimal(8, 2)
  billingCycle         String    @default("MONTHLY")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenantId String   @unique
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  invoices Invoice[]

  @@index([status])
  @@index([plan])
}

model Invoice {
  id             String    @id @default(cuid())
  number         String    @unique
  amount         Decimal   @db.Decimal(12, 2)
  currency       String    @default("USD")
  status         String    @default("PAID")
  paidAt         DateTime?
  stripeInvoiceId String?
  pdfUrl         String?
  createdAt      DateTime  @default(now())

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
}

// ============= TENANT CONFIG =============
model TenantConfig {
  id           String   @id @default(cuid())
  businessName String?
  businessType String?
  taxId        String?
  address      String?
  phone        String?
  email        String?
  timezone     String   @default("America/Argentina/Buenos_Aires")
  currency     String   @default("ARS")
  language     String   @default("es")
  darkMode     Boolean  @default(true)
  logoUrl      String?
  lowStockAlert Boolean @default(true)
  themeColor   String?  // hex like "#8b5cf6" — overrides default brand accent
  themeMode    String?  // "dark" | "light" | "auto" (light/auto coming soon)

  // WhatsApp notification settings
  whatsappPhone           String?  // E.164 like "+5491112345678"
  whatsappLowStockAlerts  Boolean  @default(false)
  whatsappDailySummary    Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ============= AUDIT =============
model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  oldValue  String?
  newValue  String?
  ipAddress String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}
