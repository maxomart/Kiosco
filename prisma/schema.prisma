datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============= MULTI-TENANT CORE =============
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  products    Product[]
  sales       Sale[]
  clients     Client[]
  suppliers   Supplier[]
  expenses    Expense[]
  recharges   Recharge[]
  cashSessions CashSession[]
  categories  Category[]
  config      TenantConfig?
  subscription Subscription?
  apiKeys     ApiKey[]
  combos      Combo[]
  clientPayments ClientPayment[]
  productLosses ProductLoss[]

  @@index([active])
  @@index([createdAt])
}

// ============= API KEYS (BUSINESS plan) =============
model ApiKey {
  id          String    @id @default(cuid())
  name        String                                   // human-friendly label
  prefix      String                                   // first 8 chars for display
  hashedKey   String    @unique                        // sha256 of the full key
  scopes      String    @default("read")               // comma-separated: read,write
  lastUsedAt  DateTime?
  expiresAt   DateTime?                                // optional rotation
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User   @relation("ApiKeyCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([prefix])
}

// ============= AUTH & USERS =============
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String?
  phone     String?
  role      String   @default("CASHIER")
  active    Boolean  @default(true)
  image     String?
  // Set when the user proves they own the email (typed the 6-digit code
  // we sent at signup). null = pending verification, can't access the
  // dashboard yet. Existing pre-feature users are backfilled at deploy.
  emailVerified DateTime?
  // null = first-time user, dashboard layout will trigger the guided tour
  // on next render. Set once they finish or skip the tour. Plan upgrades
  // re-trigger by clearing this back to null.
  tourCompletedAt DateTime?
  // Last plan we showed a "what's new" welcome for. When user upgrades,
  // we compare this to current plan to know if we should pop the modal.
  lastWelcomedPlan String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String?
  tenant   Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sales          Sale[]
  stockMovements StockMovement[]
  auditLogs      AuditLog[]
  cashSessions   CashSession[]
  apiKeysCreated ApiKey[]        @relation("ApiKeyCreatedBy")
  clientPayments ClientPayment[]

  @@index([email])
  @@index([tenantId])
  @@index([role])
  @@index([phone])
}

// ============= PRODUCTS & INVENTORY =============
model Product {
  id           String   @id @default(cuid())
  name         String
  description  String?
  sku          String?
  barcode      String?
  costPrice    Decimal  @default(0) @db.Decimal(10, 2)
  salePrice    Decimal  @default(0) @db.Decimal(10, 2)
  stock        Int      @default(0)
  minStock     Int      @default(5)
  maxStock     Int?
  active       Boolean  @default(true)
  image        String?
  soldByWeight Boolean  @default(false)
  expiryDate   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  saleItems      SaleItem[]
  stockMovements StockMovement[]
  comboItems     ComboItem[]
  losses         ProductLoss[]
  priceHistory   PriceHistory[]
  rechargeItems  RechargeItem[]

  @@unique([barcode, tenantId])
  @@unique([sku, tenantId])
  @@index([tenantId])
  @@index([active])
  @@index([categoryId])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([name, tenantId])
  @@index([tenantId])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  cuit      String?
  contact   String?
  phone     String?
  email     String?
  address   String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]
  recharges Recharge[]

  @@index([tenantId])
  @@index([active])
}

model StockMovement {
  id          String   @id @default(cuid())
  type        String   // SALE, PURCHASE, ADJUSTMENT, RETURN, LOSS
  quantity    Int
  stockBefore Int
  stockAfter  Int
  unitCost    Decimal? @db.Decimal(10, 2)
  totalCost   Decimal? @db.Decimal(10, 2)
  reason      String?
  reference   String?
  createdAt   DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

// ============= SALES =============
model Sale {
  id              String   @id @default(cuid())
  number          Int
  subtotal        Decimal  @db.Decimal(12, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(12, 2)
  discountPercent Decimal  @default(0) @db.Decimal(5, 2)
  taxAmount       Decimal  @default(0) @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)
  paymentMethod   String   @default("CASH")
  cashReceived    Decimal? @db.Decimal(12, 2)
  change          Decimal? @db.Decimal(12, 2)
  status          String   @default("COMPLETED")
  cancelReason    String?
  notes           String?
  invoiceType     String?  // "A" | "B" | "C" | "M" | "X" (X = ticket no fiscal)
  // ─── AFIP electronic invoice fields ───────────────────────────────
  cae             String?              // AFIP Authorization Code (CAE)
  caeExpiresAt    DateTime?            // CAE valid until
  pointOfSale     Int?                 // Punto de venta (1, 2, …)
  invoiceNumber   Int?                 // Número de factura asignado por AFIP
  afipQrUrl       String?              // QR data URL per RG 4892/2020
  afipStatus      String?              // PENDING | APPROVED | REJECTED | NOT_REQUESTED
  afipError       String?              // Error message from AFIP if rejected
  customerDocType String?              // CUIT | CUIL | DNI | EXTRANJERO
  customerDocNumber String?            // matched number
  customerCondicionIVA String?         // RI | MONOTRIBUTO | EXENTO | CF
  // ──────────────────────────────────────────────────────────────────
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id])
  cashSessionId String?
  cashSession   CashSession? @relation(fields: [cashSessionId], references: [id])

  items                SaleItem[]
  loyaltyTransactions  LoyaltyTransaction[]

  @@unique([number, tenantId])
  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model SaleItem {
  id          String  @id @default(cuid())
  productName String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  costPrice   Decimal @db.Decimal(10, 2)
  discount    Decimal @default(0) @db.Decimal(5, 2)
  subtotal    Decimal @db.Decimal(12, 2)
  taxRate     String  @default("STANDARD")
  taxAmount   Decimal @default(0) @db.Decimal(12, 2)

  productId String
  product   Product @relation(fields: [productId], references: [id])
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([productId])
}

// ============= CLIENTS & LOYALTY =============
model Client {
  id            String   @id @default(cuid())
  name          String
  phone         String?
  email         String?
  dni           String?
  address       String?
  notes         String?
  active        Boolean  @default(true)
  loyaltyPoints Int      @default(0)
  // ─── Cuenta corriente (credit account) ──────────────
  creditLimit       Decimal  @default(0) @db.Decimal(12, 2)  // 0 = no credit
  currentBalance    Decimal  @default(0) @db.Decimal(12, 2)  // owed by client (positive = client owes)
  // ─── AFIP / fiscal ───────────────────────────────────
  docType           String?  // CUIT | CUIL | DNI | EXTRANJERO
  docNumber         String?  // For invoice A/B
  condicionIVA      String?  // RI | MONOTRIBUTO | EXENTO | CF
  // ──────────────────────────────────────────────────────
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sales               Sale[]
  loyaltyTransactions LoyaltyTransaction[]
  payments            ClientPayment[]

  @@unique([dni, tenantId])
  @@index([tenantId])
  @@index([active])
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  points      Int
  description String
  createdAt   DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  saleId   String?
  sale     Sale?   @relation(fields: [saleId], references: [id])

  @@index([clientId])
}

// ============= CASH REGISTER =============
model CashSession {
  id             String    @id @default(cuid())
  status         String    @default("OPEN")
  openingBalance Decimal   @db.Decimal(12, 2)
  closingBalance Decimal?  @db.Decimal(12, 2)
  difference     Decimal?  @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime  @default(now())
  closedAt       DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  sales Sale[]

  @@index([tenantId])
  @@index([status])
}

// ============= EXPENSES & RECHARGES =============
model Expense {
  id        String   @id @default(cuid())
  category  String
  amount    Decimal  @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([createdAt])
}

model Recharge {
  id        String   @id @default(cuid())
  number    Int
  cost      Decimal  @db.Decimal(12, 2)
  profit    Decimal  @db.Decimal(12, 2)
  amount    Decimal  @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime @default(now())

  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  items      RechargeItem[]

  @@unique([number, tenantId])
  @@index([tenantId])
}

// ============= SUBSCRIPTIONS =============
model Subscription {
  id                   String    @id @default(cuid())
  plan                 String    @default("STARTER")
  status               String    @default("ACTIVE")
  priceUSD             Decimal   @default(0) @db.Decimal(8, 2)
  billingCycle         String    @default("MONTHLY")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  // ─── MercadoPago Suscripciones (billing en ARS) ─────────────────────
  mpPreapprovalId      String?    // Preapproval ID returned by MP
  mpStatus             String?    // pending | authorized | paused | cancelled
  paymentProvider      String?    // "stripe" | "mercadopago"
  // ────────────────────────────────────────────────────────────────────
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenantId String   @unique
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  invoices Invoice[]

  @@index([status])
  @@index([plan])
}

model Invoice {
  id             String    @id @default(cuid())
  number         String    @unique
  amount         Decimal   @db.Decimal(12, 2)
  currency       String    @default("USD")
  status         String    @default("PAID")
  paidAt         DateTime?
  stripeInvoiceId String?
  pdfUrl         String?
  createdAt      DateTime  @default(now())

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
}

// ============= TENANT CONFIG =============
model TenantConfig {
  id           String   @id @default(cuid())
  businessName String?
  businessType String?
  taxId        String?
  address      String?
  phone        String?
  email        String?
  timezone     String   @default("America/Argentina/Buenos_Aires")
  currency     String   @default("ARS")
  language     String   @default("es")
  darkMode     Boolean  @default(true)
  logoUrl      String?
  lowStockAlert Boolean @default(true)
  themeColor   String?  // hex like "#8b5cf6" — overrides default brand accent
  themeMode    String?  // "dark" | "light" | "auto" (light/auto coming soon)

  // WhatsApp notification settings
  whatsappPhone           String?  // E.164 like "+5491112345678"
  whatsappLowStockAlerts  Boolean  @default(false)
  whatsappDailySummary    Boolean  @default(false)

  // Email notifications
  notificationEmail       String?  // where to send digests (defaults to owner email)
  emailLowStockAlerts     Boolean  @default(false)
  emailDailySummary       Boolean  @default(false)
  emailWeeklySummary      Boolean  @default(false)
  emailMonthlySummary     Boolean  @default(false)
  emailIncludeAIInsights  Boolean  @default(true)
  // Hour of day to send daily digest (0-23, local timezone)
  emailDailyHour          Int      @default(22)

  // Onboarding / first-time user experience
  onboardingDismissed     Boolean  @default(false)

  // Loyalty program settings (PROFESSIONAL+ feature)
  loyaltyEnabled          Boolean  @default(false)
  loyaltyPointsPerPeso    Decimal  @default(1)    @db.Decimal(8, 4)  // 1 = 1 point per ARS spent
  loyaltyPointValue       Decimal  @default(1)    @db.Decimal(8, 4)  // 1 = each point worth $1 ARS

  // ─── AFIP / fiscal config ─────────────────────────────────────────────
  afipEnabled         Boolean  @default(false)         // Master switch
  afipMode            String   @default("HOMOLOGACION") // HOMOLOGACION | PRODUCCION
  afipCondicionIVA    String?                           // RI | MONOTRIBUTO | EXENTO
  afipPointOfSale     Int?     @default(1)              // Punto de venta default
  afipCertProvider    String?                           // "tusfacturas" | "afipsdk" | "self"
  afipCertCuit        String?                           // CUIT del emisor (sin guiones)
  afipCertSecret      String?  @db.Text                 // API token of provider OR encrypted cert ref
  afipLastSyncAt      DateTime?
  afipLastError       String?  @db.Text

  // MercadoPago integration
  mpAccessToken       String?  @db.Text                 // Access token of merchant's MP account
  mpPublicKey         String?
  mpUserId            String?
  mpStoreId           String?                           // For QR Pro

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ============= AUDIT =============
model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  oldValue  String?
  newValue  String?
  ipAddress String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

// ============= ADMIN SECURITY (super-admin only) =============
// Device-binding for the super-admin panel: any new fingerprint asking
// for /admin access has to verify with an email code first, then gets
// added here. See lib/admin-device.ts.

model AdminTrustedDevice {
  id          String   @id @default(cuid())
  userId      String
  fingerprint String   // hex digest of UA + screen + tz + canvas signal
  label       String?  // user-set, e.g. "MacBook personal"
  ipAddress   String?
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime @default(now())
  revokedAt   DateTime?

  @@unique([userId, fingerprint])
  @@index([userId])
}

model AdminDeviceChallenge {
  id          String   @id @default(cuid())
  userId      String
  fingerprint String
  codeHash    String   // sha256 of the 6-digit code (we never store plaintext)
  ipAddress   String?
  userAgent   String?  @db.Text
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// Email verification codes — one-time 6-digit codes we send at signup.
// We store sha256(code) only and let it expire after 30 minutes.
model EmailVerificationCode {
  id         String   @id @default(cuid())
  userId     String
  codeHash   String
  ipAddress  String?
  userAgent  String?  @db.Text
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ============= SUPPORT TICKETS =============
// In-app support: a tenant user opens the help widget, asks a question,
// the AI tries first, and if it can't help (or the user explicitly asks
// for a human) the ticket gets escalated to the super-admin's inbox at
// /admin/soporte. Ticket lifecycle:
//   OPEN     — user wrote, AI hasn't replied yet
//   AI_REPLIED — AI answered, awaiting user follow-up
//   ESCALATED  — user asked for human OR AI tagged it as out-of-scope
//   ANSWERED   — admin replied, awaiting user
//   CLOSED     — user marked as solved, or auto-closed after 7 days idle
model SupportTicket {
  id            String   @id @default(cuid())
  tenantId      String?
  userId        String
  subject       String
  status        String   @default("OPEN")
  priority      String   @default("NORMAL") // LOW | NORMAL | HIGH
  escalatedAt   DateTime?
  closedAt      DateTime?
  unreadByAdmin Boolean  @default(true)
  unreadByUser  Boolean  @default(false)
  // Snapshot of user's plan at creation time, helps the AI tune answers
  // and helps the admin triage without joining tables.
  planSnapshot  String?
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages SupportMessage[]

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([lastMessageAt])
}

model SupportMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  role      String   // "user" | "ai" | "admin"
  content   String   @db.Text
  authorId  String?  // null for AI; userId for user/admin
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([createdAt])
}

// Admin-private notes per tenant — internal CRM, not visible to tenants.
model AdminTenantNote {
  id        String   @id @default(cuid())
  tenantId  String
  authorId  String
  body      String   @db.Text
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([createdAt])
}

// ============= CUENTA CORRIENTE (client credit accounts) =============
model ClientPayment {
  id          String   @id @default(cuid())
  amount      Decimal  @db.Decimal(12, 2)         // positive = client paid us
  paymentMethod String @default("CASH")
  reference   String?                              // ref number, transfer id, etc.
  notes       String?
  createdAt   DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([clientId])
  @@index([createdAt])
}

// ============= COMBOS / PROMOTIONS =============
model Combo {
  id          String   @id @default(cuid())
  name        String
  description String?
  // Pricing strategy: FIXED (fixed combo price), DISCOUNT_PCT (% off when buying all items)
  type        String   @default("FIXED")
  fixedPrice  Decimal? @db.Decimal(12, 2)         // If type=FIXED
  discountPct Decimal? @db.Decimal(5, 2)          // If type=DISCOUNT_PCT
  active      Boolean  @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  items ComboItem[]

  @@index([tenantId])
  @@index([active])
}

model ComboItem {
  id        String  @id @default(cuid())
  quantity  Int     @default(1)

  comboId   String
  combo     Combo   @relation(fields: [comboId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([comboId, productId])
  @@index([comboId])
}

// ============= PROMO CODES (launch campaigns, partner coupons) =============
// Applied at signup to grant a paid plan for a limited time without charging.
// Counter is global (not per-tenant) and shared with all signups using the code.
model PromoCode {
  id           String   @id @default(cuid())
  code         String   @unique                      // user-facing (lowercased), e.g. "lanzamiento"
  description  String?
  planGranted  String                                 // "STARTER" | "PROFESSIONAL" | "BUSINESS"
  daysGranted  Int                                    // e.g. 90 for 3 months
  maxUses      Int                                    // cupo total
  usedCount    Int      @default(0)                   // incremented atomically on signup
  active       Boolean  @default(true)
  expiresAt    DateTime?                              // optional cutoff date
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  redemptions PromoRedemption[]

  @@index([active])
}

model PromoRedemption {
  id          String   @id @default(cuid())
  email       String                                   // signup email (for audit/support)
  tenantId    String                                   // no FK to Tenant so history survives tenant delete
  createdAt   DateTime @default(now())
  // Reminders flow: 0 = none sent, 1 = ~30 days left, 2 = ~10 days, 3 = 1 day
  // Bumped by /api/cron/promo-reminders so we don't double-notify on daily ticks.
  remindersSent Int    @default(0)

  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, tenantId])
  @@index([promoCodeId])
  @@index([email])
}

// ============= PURCHASE ITEMS (cargas) =============
model RechargeItem {
  id          String  @id @default(cuid())
  quantity    Int
  unitCost    Decimal @db.Decimal(10, 2)
  totalCost   Decimal @db.Decimal(12, 2)
  productName String

  rechargeId String
  recharge   Recharge @relation(fields: [rechargeId], references: [id], onDelete: Cascade)
  productId  String?
  product    Product? @relation(fields: [productId], references: [id])

  @@index([rechargeId])
  @@index([productId])
}

// ============= ANALYTICS & LOSSES =============
model ProductLoss {
  id             String   @id @default(cuid())
  type           String   // "EXPIRED" | "DAMAGED" | "THEFT"
  quantity       Int
  estimatedValue Decimal  @db.Decimal(12, 2)
  reason         String?
  createdAt      DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
  @@index([createdAt])
  @@index([type])
}

model PriceHistory {
  id        String   @id @default(cuid())
  costPrice Decimal  @db.Decimal(10, 2)
  salePrice Decimal  @db.Decimal(10, 2)
  reason    String?  // "ADJUSTMENT" | "SUPPLIER" | "PROMO"
  createdAt DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
}
